<Window x:Class="Artnet.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Artnet.Views"
        mc:Ignorable="d"
        Title="Art-Net to USB DMX Node Server" Height="780" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#0C0C0E"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="BgDark" Color="#0C0C0E"/>
        <SolidColorBrush x:Key="PanelBg" Color="#16161A"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#2A2A35"/>
        <SolidColorBrush x:Key="TextLight" Color="#F0F0F5"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8F8FA3"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#00E5FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00E676"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF1744"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FF9100"/>
        
        <!-- Styles -->
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#22222B"/>
            <Setter Property="Foreground" Value="#121214"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#22222B"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#005573"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#00E5FF"/>
                                <Setter Property="Foreground" Value="#0C0C0E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#22222B"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBlue}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR (CONFIG & CONTROLS) -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Server Status & Logo -->
            <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="16,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="ART-NET SERVER NODE" Foreground="{StaticResource AccentBlue}" FontWeight="Black" FontSize="18"/>
                            <TextBlock Text="DMX USB Interface Gateway" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Medium" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- LED Status -->
                        <Border Name="StatusLed" Grid.Column="1" Width="14" Height="14" CornerRadius="7" Background="#3E3E4A" VerticalAlignment="Center" ToolTip="Stato Server">
                            <Border.Effect>
                                <DropShadowEffect x:Name="LedGlow" Color="#3E3E4A" BlurRadius="8" ShadowDepth="0"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                    
                    <Separator Margin="0,12,0,12" Background="{StaticResource PanelBorder}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Stato Server:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontSize="13"/>
                        <TextBlock x:Name="TxtStatusLabel" Grid.Column="1" Text="SPENTO" Foreground="{StaticResource TextMuted}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Configuration -->
            <Border Grid.Row="1" Style="{StaticResource PanelCard}">
                <StackPanel>
                    <TextBlock Text="Configurazione Rete ed IP" Style="{StaticResource HeaderLabel}"/>
                    
                    <!-- Network IP -->
                    <TextBlock Text="Indirizzo IP Locale" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="ComboIpAddress" Style="{StaticResource ModernComboBox}"/>

                    <!-- UDP Port -->
                    <TextBlock Text="Porta UDP" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtPort" Text="6454" Style="{StaticResource ModernTextBox}" IsReadOnly="True"/>

                    <!-- Add Interface Section -->
                    <Border Background="#1C1C24" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,4,0,8">
                        <StackPanel>
                            <TextBlock Text="Aggiungi Nuova Interfaccia" Foreground="{StaticResource AccentBlue}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Universo Art-Net" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="ComboUniverse" Style="{StaticResource ModernComboBox}">
                                        <ComboBoxItem Content="0" IsSelected="True"/>
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="3"/>
                                        <ComboBoxItem Content="4"/>
                                        <ComboBoxItem Content="5"/>
                                        <ComboBoxItem Content="6"/>
                                        <ComboBoxItem Content="7"/>
                                        <ComboBoxItem Content="8"/>
                                        <ComboBoxItem Content="9"/>
                                        <ComboBoxItem Content="10"/>
                                        <ComboBoxItem Content="11"/>
                                        <ComboBoxItem Content="12"/>
                                        <ComboBoxItem Content="13"/>
                                        <ComboBoxItem Content="14"/>
                                        <ComboBoxItem Content="15"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Porta COM" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ComboComPort" Style="{StaticResource ModernComboBox}" Margin="0,0,4,12"/>
                                        <Button x:Name="BtnRefreshCom" Grid.Column="1" Width="30" Height="30" Margin="0,0,0,12" Background="#22222B" BorderBrush="{StaticResource PanelBorder}" Click="BtnRefreshCom_Click" ToolTip="Aggiorna Porte COM">
                                            <Path Data="M10,20A10,10 0 1,1 20,10A10,10 0 0,1 10,20M10,2A8,8 0 1,0 18,10H15L19,14L23,10H20A10,10 0 0,0 10,2Z" Fill="{StaticResource TextLight}" Width="12" Height="12" Stretch="Uniform"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Interfaccia USB DMX" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="ComboDmxDriver" Style="{StaticResource ModernComboBox}" SelectionChanged="ComboDmxDriver_SelectionChanged">
                                <ComboBoxItem Content="Simulatore (Senza Hardware)" IsSelected="True"/>
                                <ComboBoxItem Content="Enttec DMX USB Pro"/>
                                <ComboBoxItem Content="Open DMX USB"/>
                                <ComboBoxItem Content="Enttec DMX USB Pro Mk2"/>
                                <ComboBoxItem Content="FTDI Generic DMX (OpenDMX clone)"/>
                                <ComboBoxItem Content="uDMX (Eurolite / Velleman / clone)"/>
                                <ComboBoxItem Content="DMX4ALL USB Interface"/>
                                <ComboBoxItem Content="Chauvet Xpress USB"/>
                                <ComboBoxItem Content="Eurolite USB-DMX512 Pro"/>
                                <ComboBoxItem Content="Generic HID DMX (fallback)"/>
                            </ComboBox>

                            <Button x:Name="BtnAddDevice" Height="30" Background="#0A2416" BorderBrush="#008040" BorderThickness="1" Click="BtnAddDevice_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="{StaticResource AccentGreen}" Stretch="Uniform" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="AGGIUNGI INTERFACCIA" Foreground="{StaticResource AccentGreen}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- List of Configured Interfaces -->
                    <TextBlock Text="Interfacce Attive" Style="{StaticResource FieldLabel}" Margin="0,6,0,2"/>
                    <ListBox x:Name="ListConfiguredDevices" Height="100" Background="#0A0A0F" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" Foreground="{StaticResource TextLight}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1" Width="20" Height="20" Margin="4,0,0,0" Background="#290E13" BorderBrush="#800010" Click="BtnRemoveDevice_Click" Tag="{Binding}" ToolTip="Rimuovi Interfaccia">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="3"/>
                                            </Style>
                                        </Button.Resources>
                                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{StaticResource AccentRed}" Stretch="Uniform" Width="8" Height="8"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Control Play / Stop -->
            <Border Grid.Row="2" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Pannello di Controllo" Style="{StaticResource HeaderLabel}"/>

                    <!-- Play/Stop Buttons -->
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- PLAY -->
                        <Button x:Name="BtnPlay" Grid.Column="0" Height="70" Background="#0A2416" BorderBrush="#008040" BorderThickness="2" Click="BtnPlay_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,5V19L19,12L8,5Z" Fill="{StaticResource AccentGreen}" Stretch="Uniform" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="AVVIA" Foreground="{StaticResource AccentGreen}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- STOP -->
                        <Button x:Name="BtnStop" Grid.Column="2" Height="70" Background="#290E13" BorderBrush="#800010" BorderThickness="2" Click="BtnStop_Click" IsEnabled="False">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M18,18H6V6H18V18Z" Fill="{StaticResource AccentRed}" Stretch="Uniform" Width="18" Height="18" Margin="0,0,8,0"/>
                                <TextBlock Text="FERMA" Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- BLACKOUT Button -->
                    <ToggleButton x:Name="BtnBlackout" Grid.Row="2" Height="40" Margin="0,12,0,0" Background="#261C08" BorderBrush="#B26A00" BorderThickness="1.5" Click="BtnBlackout_Click" IsEnabled="False">
                        <ToggleButton.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </ToggleButton.Resources>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,7V13H13V7H11M11,15V17H13V15H11Z" Fill="{StaticResource AccentOrange}" Stretch="Uniform" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="BLACKOUT" Foreground="{StaticResource AccentOrange}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Realtime Statistics -->
                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <Separator Background="{StaticResource PanelBorder}" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="FPS (Frequenza):" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="TxtFps" HorizontalAlignment="Right" Text="0" Foreground="{StaticResource AccentBlue}" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Pacchetti Totali:" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="TxtTotalPackets" HorizontalAlignment="Right" Text="0" Foreground="{StaticResource TextLight}"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Ultimo Mittente:" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="TxtLastSender" HorizontalAlignment="Right" Text="N/A" Foreground="{StaticResource TextLight}" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                        </Grid>
                        
                        <Separator Background="{StaticResource PanelBorder}" Margin="0,12,0,12"/>
                        
                        <StackPanel>
                            <TextBlock Text="Dashboard Web:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                            <TextBlock x:Name="TxtWebUrl" Text="Sconnesso" Foreground="{StaticResource AccentBlue}" FontWeight="SemiBold" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" Cursor="Hand" MouseLeftButtonDown="TxtWebUrl_MouseLeftButtonDown"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- MAIN PANEL (DMX VISUALIZER & LOGS) -->
        <Grid Grid.Column="1" Margin="16,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- DMX Visualizer -->
            <Border Grid.Row="0" Style="{StaticResource PanelCard}" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Monitoraggio Canali DMX" Style="{StaticResource HeaderLabel}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Universo:" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="ComboMonitorUniverse" Width="80" Height="26" Style="{StaticResource ModernComboBox}" Margin="0" SelectionChanged="ComboMonitorUniverse_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Width="12" Height="12" Background="{StaticResource AccentBlue}" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Attività Canale" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <!-- We will construct a UniformGrid of 512 channels in the code-behind for performance reasons -->
                        <UniformGrid x:Name="GridDmxChannels" Columns="16" Rows="32" Margin="2"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Splitter/Separator -->
            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Logs / Terminal Console -->
            <Border Grid.Row="2" Style="{StaticResource PanelCard}" Margin="0,4,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Log Attività del Server" Style="{StaticResource HeaderLabel}" Margin="0"/>
                        <Button x:Name="BtnClearLog" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}" FontSize="11" Click="BtnClearLog_Click" Cursor="Hand">
                            <TextBlock Text="Pulisci Log" TextDecorations="Underline"/>
                        </Button>
                    </Grid>

                    <TextBox x:Name="TxtLogConsole" Grid.Row="1" Background="#0A0A0F" Foreground="#A2A2BA" 
                             BorderBrush="#20202A" BorderThickness="1" FontFamily="Consolas, Courier New" 
                             FontSize="11" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                             AcceptsReturn="True" TextWrapping="Wrap" Padding="8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
